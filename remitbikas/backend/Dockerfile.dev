# ============================================================
# Development Dockerfile for Backend
# ============================================================
# Use this for development with hot reload
# Build: docker build -f Dockerfile.dev -t remitbikas-backend:dev .
# Run: docker run -it -p 5000:5000 -v $(pwd)/src:/app/src remitbikas-backend:dev

FROM node:20-alpine

WORKDIR /app

# Install dependencies including dev dependencies
COPY package.json package-lock.json ./
RUN npm ci

# Copy Prisma schema
COPY prisma ./prisma
RUN npx prisma generate

# Copy source code
COPY src ./src
COPY tsconfig.json ./

# Expose port
EXPOSE 5000

# Environment variables
ENV NODE_ENV=development

COPY docker-entrypoint.dev.sh ./
RUN chmod +x docker-entrypoint.dev.sh

# Sync schema and start development server with watch mode
CMD ["./docker-entrypoint.dev.sh"]
